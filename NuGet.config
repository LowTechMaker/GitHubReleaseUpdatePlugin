<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="SceneGalleryGitHub" value="https://nuget.pkg.github.com/LowTechMaker/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="SceneGalleryGitHub">
      <package pattern="SceneGallery.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
